<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/ide_background">

    <!-- Clean Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/toolbar_background"
        android:elevation="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingEnd="16dp">

            <!-- Essential Actions Only -->
            <ImageButton
                android:id="@+id/newFileBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="New"
                android:src="@android:drawable/ic_menu_add"
                android:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/openBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Open"
                android:src="@android:drawable/ic_menu_upload"
                android:tint="@color/text_primary" />

            <ImageButton
                android:id="@+id/saveBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Save"
                android:src="@android:drawable/ic_menu_save"
                android:tint="@color/text_primary" />

            <!-- Language Selector -->
            <Spinner
                android:id="@+id/langSpinner"
                android:layout_width="120dp"
                android:layout_height="40dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="8dp" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Run Button -->
            <Button
                android:id="@+id/runBtn"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@android:color/holo_green_dark"
                android:text="▶ Run"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- File Info Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@color/secondary_background"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/fileNameText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Untitled.java"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/cursorPositionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Line 1, Column 1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Code Editor Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:background="@color/editor_background">

            <!-- Line Numbers -->
            <TextView
                android:id="@+id/lineNumbers"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:background="@color/line_number_background"
                android:fontFamily="monospace"
                android:gravity="end|top"
                android:padding="8dp"
                android:text="1\n2\n3\n4\n5"
                android:textColor="@color/line_number_text"
                android:textSize="12sp" />

            <!-- Editor -->
            <ScrollView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <EditText
                        android:id="@+id/codeEditor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="monospace"
                        android:gravity="top|start"
                        android:hint="Write your code here..."
                        android:inputType="textMultiLine|textNoSuggestions"
                        android:minWidth="300dp"
                        android:padding="12dp"
                        android:scrollbars="none"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="14sp" />

                </HorizontalScrollView>
            </ScrollView>

        </LinearLayout>

        <!-- Input Section (Collapsible) -->
        <LinearLayout
            android:id="@+id/inputSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/input_background"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Input Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/input_header_background"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Program Input"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/closeInputBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- Input Field -->
            <EditText
                android:id="@+id/inputField"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_margin="12dp"
                android:background="@android:drawable/edit_text"
                android:fontFamily="monospace"
                android:gravity="top|start"
                android:hint="Enter input values (one per line)"
                android:inputType="textMultiLine"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- Output Console -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@color/console_background"
            android:orientation="vertical">

            <!-- Console Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/console_header_background"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Output"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/showInputBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Show Input"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="@color/text_secondary" />

                <ImageButton
                    android:id="@+id/clearConsoleBtn"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Clear"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- Console Output -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:padding="12dp">

                <TextView
                    android:id="@+id/outputConsole"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="Ready to run code...\n\nSelect a language and write your code above."
                    android:textColor="@color/console_text"
                    android:textSize="13sp"
                    android:textIsSelectable="true" />

            </ScrollView>

        </LinearLayout>

    </LinearLayout>

    <!-- Status Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:background="@color/status_background"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ready"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>